<Window x:Class="XrayDetector.Gui.Views.WelcomeWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="X-ray Detector 시뮬레이터 시작하기"
        Height="380" Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{Binding StepTitle}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TextBlock Text="{Binding StepContent}"
                       TextWrapping="Wrap"
                       FontSize="13"
                       LineHeight="20"/>
        </ScrollViewer>

        <!-- Don't show again checkbox -->
        <CheckBox Grid.Row="2"
                  Content="다시 보지 않기"
                  IsChecked="{Binding DontShowAgain}"
                  Margin="0,16,0,8"/>

        <!-- Navigation buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="이전"
                    Command="{Binding PreviousCommand}"
                    Width="80" Height="30"
                    Margin="0,0,8,0"/>
            <Button Content="다음"
                    Command="{Binding NextCommand}"
                    Width="80" Height="30"
                    Margin="0,0,8,0"/>
            <Button Content="완료"
                    Command="{Binding FinishCommand}"
                    Width="80" Height="30"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
