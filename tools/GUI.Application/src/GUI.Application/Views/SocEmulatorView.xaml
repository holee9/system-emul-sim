<UserControl x:Class="XrayDetector.Gui.Views.SocEmulatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">
    <ScrollViewer>
        <StackPanel Margin="16">
            <TextBlock Text="SoC Emulator" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Frame Buffer -->
            <GroupBox Header="Frame Buffer" Margin="0,0,0,12">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Buffer Count (1-8):" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding SimulatorControl.FrameBufferCount, Mode=TwoWay}"
                             Margin="0,0,0,5"
                             AutomationProperties.AutomationId="InputFrameBufferCount"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Buffer State:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding SimulatorControl.McuBufferState}"
                               FontWeight="Bold"
                               AutomationProperties.AutomationId="TxtMcuBufferState"/>
                </Grid>
            </GroupBox>

            <!-- UDP TX -->
            <GroupBox Header="UDP TX" Margin="0,0,0,12">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Target IP:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding UdpTargetIp, Mode=TwoWay}"
                             Margin="0,0,0,5"
                             AutomationProperties.AutomationId="InputUdpTargetIp"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Target Port:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding UdpTargetPort, Mode=TwoWay}"
                             AutomationProperties.AutomationId="InputUdpTargetPort"/>
                </Grid>
            </GroupBox>

            <!-- Sequence Engine -->
            <GroupBox Header="Sequence Engine" Margin="0,0,0,12">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Command State:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SequenceEngineState}"
                               FontWeight="Bold"
                               AutomationProperties.AutomationId="TxtSequenceEngineState"/>
                </Grid>
            </GroupBox>

            <!-- Pipeline Statistics -->
            <GroupBox Header="Pipeline Statistics" Margin="0,0,0,12">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Status Indicator:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding PipelineStatus.StatusIndicator}"
                               FontWeight="Bold"
                               Margin="0,0,0,5"
                               AutomationProperties.AutomationId="TxtStatusIndicator"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Frames Processed:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding PipelineStatus.FramesProcessed}"
                               Margin="0,0,0,5"
                               AutomationProperties.AutomationId="TxtFramesProcessed"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Frames Failed:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding PipelineStatus.FramesFailed}"
                               Margin="0,0,0,5"
                               AutomationProperties.AutomationId="TxtFramesFailed"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Packets Lost:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="3" Grid.Column="1"
                               Text="{Binding PipelineStatus.PacketsLost}"
                               Margin="0,0,0,5"
                               AutomationProperties.AutomationId="TxtPacketsLost"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Avg Process Time (ms):" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="4" Grid.Column="1"
                               Text="{Binding PipelineStatus.AvgProcessingTimeMs, StringFormat={}{0:F2}}"
                               AutomationProperties.AutomationId="TxtAvgProcessTimeMs"/>
                </Grid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
