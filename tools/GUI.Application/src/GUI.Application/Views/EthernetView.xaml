<UserControl x:Class="XrayDetector.Gui.Views.EthernetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">
    <ScrollViewer>
        <StackPanel Margin="16">
            <TextBlock Text="Ethernet Emulator" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Connection Status -->
            <GroupBox Header="Connection Status" Margin="0,0,0,12">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="State:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding Status.ConnectionState}"
                               FontWeight="Bold"
                               Margin="0,0,0,5"
                               AutomationProperties.AutomationId="TxtEthConnectionState"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Throughput:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding Status.ThroughputGbps, StringFormat={}{0:F2} Gbps}"
                               AutomationProperties.AutomationId="TxtEthThroughput"/>
                </Grid>
            </GroupBox>

            <!-- Network Impairment -->
            <GroupBox Header="Network Impairment" Margin="0,0,0,12">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Packet Loss (0-1):" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding SimulatorControl.PacketLossRate, Mode=TwoWay}"
                             Margin="0,0,0,5"
                             AutomationProperties.AutomationId="InputPacketLossRate"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Reorder Rate (0-1):" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding SimulatorControl.ReorderRate, Mode=TwoWay}"
                             Margin="0,0,0,5"
                             AutomationProperties.AutomationId="InputReorderRate"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Corruption (0-1):" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding SimulatorControl.CorruptionRate, Mode=TwoWay}"
                             Margin="0,0,0,5"
                             AutomationProperties.AutomationId="InputCorruptionRate"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Min Delay (ms):" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1"
                             Text="{Binding SimulatorControl.MinDelayMs, Mode=TwoWay}"
                             Margin="0,0,0,5"
                             AutomationProperties.AutomationId="InputMinDelayMs"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Max Delay (ms):" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1"
                             Text="{Binding SimulatorControl.MaxDelayMs, Mode=TwoWay}"
                             AutomationProperties.AutomationId="InputMaxDelayMs"/>
                </Grid>
            </GroupBox>

            <!-- Network Statistics -->
            <GroupBox Header="Network Statistics" Margin="0,0,0,12">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Packets Sent:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding PipelineStatus.PacketsSent}"
                               Margin="0,0,0,5"
                               AutomationProperties.AutomationId="TxtPacketsSent"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Packets Lost:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding PipelineStatus.PacketsLost}"
                               Foreground="Red"
                               Margin="0,0,0,5"
                               AutomationProperties.AutomationId="TxtEthPacketsLost"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Packets Reordered:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding PipelineStatus.PacketsReordered}"
                               Margin="0,0,0,5"
                               AutomationProperties.AutomationId="TxtPacketsReordered"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Packets Corrupted:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="3" Grid.Column="1"
                               Text="{Binding PipelineStatus.PacketsCorrupted}"
                               Foreground="Orange"
                               AutomationProperties.AutomationId="TxtPacketsCorrupted"/>
                </Grid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
