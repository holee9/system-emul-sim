<UserControl x:Class="XrayDetector.Gui.Views.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section 1: Window/Level Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8" Background="#F5F5F5">
            <TextBlock Text="Window Center:" VerticalAlignment="Center" Margin="8,0"/>
            <Slider Width="150" VerticalAlignment="Center" Minimum="0" Maximum="65535"
                    Value="{Binding WindowCenter}" TickFrequency="1000" IsSnapToTickEnabled="True"
                    AutomationProperties.AutomationId="SliderWindowCenter"/>
            <TextBox Text="{Binding WindowCenter, StringFormat={}{0:F0}}" Width="80" Margin="8,0"
                     AutomationProperties.AutomationId="InputWindowCenter"/>

            <TextBlock Text="Window Width:" VerticalAlignment="Center" Margin="16,0,0,0"/>
            <Slider Width="150" VerticalAlignment="Center" Minimum="1" Maximum="65535"
                    Value="{Binding WindowWidth}" TickFrequency="1000" IsSnapToTickEnabled="True"
                    AutomationProperties.AutomationId="SliderWindowWidth"/>
            <TextBox Text="{Binding WindowWidth, StringFormat={}{0:F0}}" Width="80" Margin="8,0"
                     AutomationProperties.AutomationId="InputWindowWidth"/>

            <Button Content="Auto W/L" Command="{Binding AutoWindowLevelCommand}"
                    Margin="16,0,8,0" Padding="12,4"
                    AutomationProperties.AutomationId="BtnAutoWindowLevel"/>
        </StackPanel>

        <!-- Frame Display -->
        <Border Grid.Row="1" BorderBrush="DarkGray" BorderThickness="1" Margin="8" Background="Black">
            <Image x:Name="FrameImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   RenderOptions.EdgeMode="Aliased"/>
        </Border>

        <!-- Frame Info Row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,0,8,4">
            <TextBlock AutomationProperties.AutomationId="TxtFrameInfo"
                       Text="{Binding FramePreview.FrameInfo}" FontWeight="Bold"/>
            <TextBlock Text=" | " Margin="8,0"/>
            <TextBlock Text="{Binding FramePreview.MinValue, StringFormat={}Min: {0}}"/>
            <TextBlock Text=" | " Margin="8,0"/>
            <TextBlock Text="{Binding FramePreview.MaxValue, StringFormat={}Max: {0}}"/>
            <TextBlock Text=" | " Margin="8,0"/>
            <TextBlock Text="{Binding FramePreview.MeanValue, StringFormat={}Mean: {0:F1}}"/>
        </StackPanel>

        <!-- Section 2 & 3: Acquisition Control + Scenario Runner -->
        <Grid Grid.Row="3" Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Acquisition Control -->
            <GroupBox Grid.Column="0" Header="Acquisition Control">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Start" Command="{Binding StartCommand}"
                                Width="80" Margin="0,0,5,0"
                                AutomationProperties.AutomationId="BtnStart"/>
                        <Button Content="Stop" Command="{Binding StopCommand}"
                                Width="80" Margin="0,0,5,0"
                                AutomationProperties.AutomationId="BtnStop"/>
                        <Button Content="Reset" Command="{Binding ResetCommand}"
                                Width="80"
                                AutomationProperties.AutomationId="BtnReset"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Scenario Runner -->
            <GroupBox Grid.Column="2" Header="Scenario Runner">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ComboBox Grid.Row="0"
                              AutomationProperties.AutomationId="CboScenarios"
                              ItemsSource="{Binding ScenarioRunner.Scenarios}"
                              SelectedItem="{Binding ScenarioRunner.SelectedScenario}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,8"/>

                    <ProgressBar Grid.Row="1"
                                 AutomationProperties.AutomationId="PrgScenario"
                                 Height="20"
                                 Value="{Binding ScenarioRunner.Progress}"
                                 Maximum="100"
                                 Margin="0,0,0,8"/>

                    <Button Grid.Row="2"
                            AutomationProperties.AutomationId="BtnExecuteScenario"
                            Content="Execute Scenario"
                            Command="{Binding ScenarioRunner.ExecuteCommand}"
                            HorizontalAlignment="Left"
                            Width="140"
                            Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="3"
                               AutomationProperties.AutomationId="TxtScenarioResult"
                               Text="{Binding ScenarioRunner.Result.Message}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Top"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
