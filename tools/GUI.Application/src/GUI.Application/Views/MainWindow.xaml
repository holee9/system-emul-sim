<Window x:Class="XrayDetector.Gui.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:XrayDetector.Gui.ViewModels"
        xmlns:views="clr-namespace:XrayDetector.Gui.Views"
        xmlns:core="clr-namespace:XrayDetector.Gui.Core"
        mc:Ignorable="d"
        Title="X-ray Detector Panel System"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding StartAcquisitionCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding StopAcquisitionCommand}"/>
        <KeyBinding Key="Q" Modifiers="Control" Command="{Binding ExitCommand}"/>
        <KeyBinding Key="F11" Command="{Binding ToggleFullScreenCommand}"/>
        <KeyBinding Key="D1" Modifiers="Alt" Command="{Binding SwitchTabCommand}" CommandParameter="0"/>
        <KeyBinding Key="D2" Modifiers="Alt" Command="{Binding SwitchTabCommand}" CommandParameter="1"/>
        <KeyBinding Key="D3" Modifiers="Alt" Command="{Binding SwitchTabCommand}" CommandParameter="2"/>
        <KeyBinding Key="D4" Modifiers="Alt" Command="{Binding SwitchTabCommand}" CommandParameter="3"/>
        <KeyBinding Key="D5" Modifiers="Alt" Command="{Binding SwitchTabCommand}" CommandParameter="4"/>
        <KeyBinding Key="D6" Modifiers="Alt" Command="{Binding SwitchTabCommand}" CommandParameter="5"/>
        <KeyBinding Key="OemQuestion" Modifiers="Control" Command="{Binding ShowShortcutOverlayCommand}"/>
        <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#F0F0F0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Config..." Command="{Binding OpenConfigCommand}"/>
                <MenuItem Header="_Save Frame..." Command="{Binding SaveFrameCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit"
                          Command="{Binding ExitCommand}"
                          AutomationProperties.AutomationId="MenuFileExit"/>
            </MenuItem>
            <MenuItem Header="_Connection">
                <MenuItem Header="_Connect" Command="{Binding ConnectCommand}"/>
                <MenuItem Header="_Disconnect" Command="{Binding DisconnectCommand}"/>
            </MenuItem>
            <MenuItem Header="_Acquisition">
                <MenuItem Header="_Start" Command="{Binding StartAcquisitionCommand}"/>
                <MenuItem Header="S_top" Command="{Binding StopAcquisitionCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Status Bar"
                          IsCheckable="True"
                          IsChecked="{Binding IsStatusBarVisible}"
                          Command="{Binding ToggleStatusBarCommand}"
                          AutomationProperties.AutomationId="MenuViewStatusBar"/>
                <MenuItem Header="_Full Screen"
                          Command="{Binding ToggleFullScreenCommand}"
                          AutomationProperties.AutomationId="MenuViewFullScreen"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_도움말 항목"
                          Command="{Binding ShowHelpCommand}"
                          AutomationProperties.AutomationId="MenuHelpTopics"/>
                <MenuItem Header="_About"
                          Command="{Binding ShowAboutCommand}"
                          AutomationProperties.AutomationId="MenuHelpAbout"/>
            </MenuItem>
        </Menu>

        <!-- Connection Bar -->
        <Border Grid.Row="1" Background="#E8E8E8" BorderBrush="#CCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,4">
                <TextBlock Text="Host:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding HostAddress, UpdateSourceTrigger=PropertyChanged}"
                         Width="130" Margin="0,0,4,0"/>
                <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                         Width="55" Margin="0,0,8,0"/>
                <Button Content="Connect" Command="{Binding ConnectCommand}" Padding="10,2" Margin="0,0,4,0"/>
                <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Padding="10,2"/>
            </StackPanel>
        </Border>

        <!-- Pipeline Integration Toolbar (SPEC-GUI-002) -->
        <Border Grid.Row="2" Background="#2D2D2D" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Module Status Indicators — Foreground bound to IsReady via BoolToBrushConverter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="● Panel"
                               Foreground="{Binding PanelViewModel.IsReady, Converter={StaticResource BoolToBrushConverter}}"
                               FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"
                               AutomationProperties.AutomationId="ModuleStatusPanel"/>
                    <TextBlock Text="● FPGA"
                               Foreground="{Binding FpgaViewModel.IsReady, Converter={StaticResource BoolToBrushConverter}}"
                               FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"
                               AutomationProperties.AutomationId="ModuleStatusFpga"/>
                    <TextBlock Text="● SoC"
                               Foreground="{Binding SocViewModel.IsReady, Converter={StaticResource BoolToBrushConverter}}"
                               FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"
                               AutomationProperties.AutomationId="ModuleStatusSoc"/>
                    <TextBlock Text="● ETH"
                               Foreground="{Binding EthernetViewModel.IsReady, Converter={StaticResource BoolToBrushConverter}}"
                               FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"
                               AutomationProperties.AutomationId="ModuleStatusEth"/>
                    <TextBlock Text="● SDK"
                               Foreground="{Binding SdkHostViewModel.IsReady, Converter={StaticResource BoolToBrushConverter}}"
                               FontWeight="Bold" VerticalAlignment="Center"
                               AutomationProperties.AutomationId="ModuleStatusSdk"/>
                </StackPanel>

                <!-- Integrate & Run — bound to IntegrateAndRunCommand / StopAllCommand -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Integrate and Run"
                            Command="{Binding IntegrateAndRunCommand}"
                            Background="#4CAF50" Foreground="White"
                            FontWeight="Bold" Padding="16,4" Margin="0,0,8,0"
                            AutomationProperties.AutomationId="BtnIntegrateAndRun"/>
                    <Button Content="Stop All"
                            Command="{Binding StopAllCommand}"
                            Background="#F44336" Foreground="White"
                            FontWeight="Bold" Padding="16,4"
                            AutomationProperties.AutomationId="BtnStopAll"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content: Module-Oriented Tabbed Interface (SPEC-GUI-002) -->
        <TabControl Grid.Row="3" Margin="4" SelectedIndex="{Binding SelectedTabIndex}">

            <!-- Tab 1: Panel (Emulator/HW) -->
            <TabItem Header="Panel" AutomationProperties.AutomationId="TabPanel">
                <views:PanelEmulatorView DataContext="{Binding PanelViewModel}"/>
            </TabItem>

            <!-- Tab 2: FPGA (Emulator/HW) -->
            <TabItem Header="FPGA" AutomationProperties.AutomationId="TabFpga">
                <views:FpgaEmulatorView DataContext="{Binding FpgaViewModel}"/>
            </TabItem>

            <!-- Tab 3: SoC (Emulator/HW) -->
            <TabItem Header="SoC" AutomationProperties.AutomationId="TabSoc">
                <views:SocEmulatorView DataContext="{Binding SocViewModel}"/>
            </TabItem>

            <!-- Tab 4: Ethernet (Emulator/HW) -->
            <TabItem Header="Ethernet" AutomationProperties.AutomationId="TabEthernet">
                <views:EthernetView DataContext="{Binding EthernetViewModel}"/>
            </TabItem>

            <!-- Tab 5: Host PC SDK (Simulator/SW) -->
            <TabItem Header="Host PC" AutomationProperties.AutomationId="TabSdkHost">
                <views:SdkHostView DataContext="{Binding SdkHostViewModel}"/>
            </TabItem>

            <!-- Tab 6: Console (Simulator/SW) -->
            <TabItem Header="Console" AutomationProperties.AutomationId="TabConsole">
                <views:ConsoleView DataContext="{Binding ConsoleViewModel}"/>
            </TabItem>

        </TabControl>

        <!-- Keyboard Shortcut Overlay (Ctrl+/ toggles, click to dismiss) -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#CC000000"
                Visibility="{Binding IsShortcutOverlayVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                AutomationProperties.AutomationId="ShortcutOverlay">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding ShowShortcutOverlayCommand}"/>
            </Border.InputBindings>
            <Border Background="White" CornerRadius="8" Padding="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="400">
                <StackPanel>
                    <TextBlock Text="Keyboard Shortcuts" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"
                               HorizontalAlignment="Center"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+R" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Start Acquisition" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+S" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Stop Acquisition" Margin="0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+Q" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Exit" Margin="0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="F11" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Toggle Full Screen" Margin="0,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Alt+1 ~ Alt+6" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Switch Tab (Panel/FPGA/SoC/Ethernet/Host/Console)" Margin="0,4"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ctrl+/" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="Show / Hide This Panel" Margin="0,4"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="F1" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="Open Help" Margin="0,4"/>
                    </Grid>
                    <TextBlock Text="Click anywhere to close" Foreground="Gray" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4"
                   AutomationProperties.AutomationId="StatusBarMain"
                   Visibility="{Binding IsStatusBarVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock AutomationProperties.AutomationId="StatusBarVersion"
                           Text="{Binding AppVersion, StringFormat={}v{0}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
